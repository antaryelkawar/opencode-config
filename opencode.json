{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/coding",
  "small_model": "litellm/fast",
  "shell": "pwsh",
  "provider": {
    "litellm": {
      "options": {
        "baseURL": "http://192.168.1.103:4000/v1",
        "apiKey": "sk-litellm-master-key"
      },
      "models": {
        "primary": {
          "name": "Primary (Best coding models)"
        },
        "coding": {
          "name": "Coding"
        },
        "premium": {
          "name": "Premium"
        },
        "balanced": {
          "name": "Balanced"
        },
        "fast": {
          "name": "Fast"
        },
        "smart": {
          "name": "Smart"
        },
        "local-model": {
          "name": "Local"
        }
      }
    }
  },
  "mcp": {
    "idea": {
      "type": "remote",
      "url": "http://127.0.0.1:64342/sse",
      "headers": {},
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "description": "Main development agent with full tool access",
      "model": "litellm/coding"
    },
    "plan": {
      "description": "Planning agent - analyzes and suggests without making changes",
      "model": "litellm/coding",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "general": {
      "description": "General-purpose agent for multi-step tasks",
      "mode": "subagent",
      "model": "litellm/balanced"
    },
    "explore": {
      "description": "Fast exploration agent - read-only code analysis",
      "mode": "subagent",
      "model": "litellm/fast",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true
      }
    },
    "code-reviewer": {
      "description": "Code review agent - analyzes code quality and suggests improvements",
      "mode": "subagent",
      "model": "litellm/premium",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "edit": false,
        "write": false
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    },
    "docs-writer": {
      "description": "Documentation writer agent - generates and maintains docs",
      "mode": "subagent",
      "model": "litellm/balanced",
      "tools": {
        "read": true,
        "write": true,
        "edit": true
      }
    },
    "security-auditor": {
      "description": "Security audit agent - finds vulnerabilities and security issues",
      "mode": "subagent",
      "model": "litellm/premium",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "edit": false,
        "write": false
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "allow"
      }
    },
    "java-expert": {
      "description": "Java/Spring expert with Maven build knowledge",
      "mode": "subagent",
      "model": "litellm/coding",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "websearch": "deny",
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "explore": "allow",
          "general": "allow"
        }
      }
    }
  },
  "default_agent": "plan",
  "command": {
    "build": {
      "template": "mvn clean install -DskipTests",
      "description": "Build the entire project"
    },
    "build-module": {
      "template": "mvn clean install -pl {module} -DskipTests",
      "description": "Build a specific module"
    },
    "test": {
      "template": "mvn test",
      "description": "Run all tests"
    },
    "test-module": {
      "template": "mvn test -pl {module}",
      "description": "Run tests for a specific module"
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
